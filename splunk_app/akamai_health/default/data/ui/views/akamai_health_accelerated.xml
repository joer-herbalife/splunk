  <row>
    <panel>
      <title>Errors [4xx, 5xx] by Host</title>
      <table>
        <search>
          <query><![CDATA[
            | tstats count AS count FROM datamodel=akamai_health WHERE nodename=web_requests BY web_requests.reqHost web_requests.statusCode
            | rename web_requests.reqHost AS reqHost, web_requests.statusCode AS statusCode
            | eval status=tonumber(statusCode)
            | eval code=case(status>=400 AND status<600, statusCode."s",
                             status=0, "zznoresp",
                             status>=200 AND status<400, "zzok",
                             true(), "zzother")
            | chart useother=f limit=0 sum(count) AS count over reqHost by code
            | addtotals fieldname=requests
            | eval total_errors=requests-coalesce(zzok,0)-coalesce(zzother,0)
            | eval "error %"=round((total_errors/requests)*100,3)
            | where total_errors > 0
            | fields - zzok - zzother - zznoresp - total_errors
            | sort - requests
            | head 20
            | table reqHost requests "error %" *
          ]]></query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="count">20</option>
        <option name="wrap">false</option>
        <option name="rowNumbers">true</option>
        <option name="drilldown">cell</option>
        <drilldown>
          <condition field="400s"><link target="_blank"><![CDATA[/app/search/search?q=search%20index%3D%22akamai_metrics_prod%22%20%7C%20spath%20input%3D_raw%20%7C%20search%20reqHost%3D%22$row.reqHost$%22%20statusCode%3D%22400%22&earliest=$time_range.earliest$&latest=$time_range.latest$]]></link></condition>
