<dashboard version="1.1">
  <label>Herbalife Akamai Website Health (Top 20)</label>
  <description>Error-focused view: availability, error rate, regional impact, and 4xx/5xx breakdown for the top 20 hosts.</description>

  <fieldset submitButton="false">
    <input type="time" token="time_range">
      <label>Time Range</label>
      <default>
        <earliest>-10h</earliest>
        <latest>now</latest>
      </default>
    </input>
  </fieldset>

  <!--
    Deprecated base search / dashboard.  See: Accelerated
  -->
  <search id="base_akamai">
    <query><![CDATA[
      index="akamai_metrics_prod"
      | rex field=_raw "\"reqHost\":\"?(?<rex_reqHost>[^\",}]+)\"?"
      | rex field=_raw "\"country\":\"?(?<rex_country>[^\",}]+)\"?"
      | rex field=_raw "\"statusCode\":\"?(?<rex_statusCode>\d+)\"?"
      | eval reqHost=coalesce(reqHost, rex_reqHost),
             country=coalesce(country, rex_country),
             status_code=coalesce(mvindex(statusCode,0), rex_statusCode),
             status=tonumber(status_code)
      | eval is_2xx=if(status>=200 AND status<300,1,0),
             is_4xx=if(status>=400 AND status<500,1,0),
             is_5xx=if(status>=500 AND status<600,1,0),
             is_no_response=if(status=0,1,0),
             is_error=if(status>=500 OR status=0,1,0)
      | eval code=case(status>=400 AND status<600, status_code."s",
                       status=0, "zznoresp",
                       status>=200 AND status<400, "zzok",
                       true(), "zzother")
      | fillnull value="-" reqHost country
    ]]></query>
    <earliest>$time_range.earliest$</earliest>
    <latest>$time_range.latest$</latest>
  </search>

  <row>
    <panel>
      <title>Availability</title>
      <single>
        <search base="base_akamai">
          <query><![CDATA[
            stats count as requests sum(is_error) as errors
            | eval availability=round(((requests-errors)/requests)*100,3)
            | fields availability
          ]]></query>
        </search>
        <option name="unit">%</option>
        <option name="colorMode">block</option>
        <option name="useColors">1</option>
        <option name="rangeColors">["0xdc4e41","0xf8be34","0x53a051"]</option>
        <option name="rangeValues">[99,99.9]</option>
        <option name="drilldown">none</option>
      </single>
    </panel>
    <panel>
      <title>Server Error Rate (5xx / no-response)</title>
      <single>
        <search base="base_akamai">
          <query><![CDATA[
            stats count as requests sum(is_error) as errors
            | eval error_rate=round((errors/requests)*100,5)
            | fields error_rate
          ]]></query>
        </search>
        <option name="unit">%</option>
        <option name="colorMode">block</option>
        <option name="useColors">1</option>
        <option name="rangeColors">["0x53a051","0xf8be34","0xdc4e41"]</option>
        <option name="rangeValues">[0.1,1]</option>
        <option name="drilldown">none</option>
      </single>
    </panel>
    <panel>
      <title>Client Error Rate (4xx)</title>
      <single>
        <search base="base_akamai">
          <query><![CDATA[
            stats count as requests sum(is_4xx) as errors_4xx
            | eval client_error_rate=round((errors_4xx/requests)*100,5)
            | fields client_error_rate
          ]]></query>
        </search>
        <option name="unit">%</option>
        <option name="colorMode">block</option>
        <option name="useColors">1</option>
        <option name="rangeColors">["0x53a051","0xf8be34","0xdc4e41"]</option>
        <option name="rangeValues">[1,5]</option>
        <option name="drilldown">none</option>
      </single>
    </panel>
  </row>

  <row>
    <panel>
      <title>Total Requests by 4xx &amp; 5xx Over Time</title>
      <chart>
        <search>
          <query><![CDATA[
            index="akamai_metrics_prod"
            | rex field=_raw "\"statusCode\":\"?(?<rex_statusCode>\d+)\"?"
            | eval status=tonumber(coalesce(mvindex(statusCode,0), rex_statusCode))
            | eval is_4xx=if(status>=400 AND status<500,1,0),
                   is_5xx=if(status>=500 AND status<600,1,0)
            | timechart span=5m sum(is_4xx) as 4xx sum(is_5xx) as 5xx
          ]]></query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="charting.chart">line</option>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.axisTitleY.text">Requests</option>
        <option name="charting.legend.placement">bottom</option>
        <option name="charting.drilldown">none</option>
      </chart>
    </panel>
  </row>

